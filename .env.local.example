# ---- Neo4j (the knowledge graph) ----
# Option A: Neo4j Aura free tier  -> https://neo4j.com/cloud/aura-free/  (URI looks like neo4j+s://xxxx.databases.neo4j.io)
# Option B: local via Homebrew     -> `brew install neo4j && neo4j start`  (URI bolt://localhost:7687)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ---- Last.fm (similar artists + tags) ----
# Free instant key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ---- MusicBrainz (no key; just identify yourself per their rules) ----
MUSICBRAINZ_USER_AGENT=MusicGenomeProject/0.1 ( hayeshelsper@gmail.com )

# ---- LLM synthesis layer ----
# LLM_PROVIDER = ollama (default, local) | anthropic | openai
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Only needed if LLM_PROVIDER=anthropic / openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
