# =============================================================
#  THE MUSIC GENOME PROJECT — environment
#  Fill what you need. The MVP only needs the first 3 sections.
#  The rest unlock later pages and can stay blank for now.
# =============================================================

# ===== REQUIRED FOR THE MVP =====================================

# ---- Neo4j (the knowledge graph) ----
# Option A: Neo4j Aura free tier -> https://console.neo4j.io  (URI looks like neo4j+s://xxxx.databases.neo4j.io)
# Option B: local via Homebrew   -> `brew install neo4j && brew services start neo4j`  (URI bolt://localhost:7687)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ---- MusicBrainz (NO key — just identify yourself per their rules) ----
MUSICBRAINZ_USER_AGENT=MusicGenomeProject/0.1 ( hayeshelsper@gmail.com )

# ---- LLM synthesis layer ----
# LLM_PROVIDER = ollama (default, local, no cost) | anthropic | openai
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ===== OPTIONAL ENRICHMENT (MVP works without these) ===========

# ---- Last.fm (similar artists + tags) ----
# Free instant key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ===== FUTURE PAGES (sign up now so it's all in one place) ======

# ---- Discogs (producer/engineer credits -> Producer Breakdown) ----
# Personal access token, instant: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# ---- Genius (lyrics/themes -> Songwriter Copilot) ----
# Client access token, instant: https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# ---- Setlist.fm (concerts -> Concert Intelligence) ----
# API key (request form, usually instant): https://www.setlist.fm/settings/api
SETLISTFM_API_KEY=

# ---- Spotify (read YOUR OWN library -> Playlist/Personal DNA) ----
# Dashboard app: https://developer.spotify.com/dashboard
# NOTE: Spotify no longer allows http://localhost redirects — use the loopback IP.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

# ---- Hosted LLM (only if you ever want to swap off local Ollama) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
